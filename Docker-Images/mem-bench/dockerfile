FROM node:22-slim
WORKDIR /app
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    && apt-get clean && rm -rf /var/lib/apt/lists/*
COPY package*.json ./
RUN npm install
COPY . .
RUN g++ -o program exec.cpp
ENV PORT=3000
#AVOID CLOUDFLARE CONNECTION
ENV NPM_CONFIG_UPDATE_NOTIFIER=false
ENV NO_UPDATE_NOTIFIER=1
#
EXPOSE 3000
CMD ["npm", "start"]